generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  FOOD
  TRANSPORT
  HOUSING
  SHOPPING
  SALARY
  OTHER
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  goals        Goal[]        // 🚀 ADICIONADO: Relação com as caixinhas
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // INCOME | EXPENSE
  category    Category @default(OTHER)
  description String
  date        DateTime
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

// 🚀 NOVO MODELO: CAIXINHAS (METAS)
model Goal {
  id          String   @id @default(uuid())
  name        String   // Nome da caixinha (ex: "Novo PC", "Reserva")
  target      Float    // Valor final da meta
  current     Float    @default(0) // Valor já guardado
  icon        String   @default("Wallet") // Nome do ícone do Lucide
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}